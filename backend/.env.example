# PetSphere Backend - Environment Variables
# Copy this file to .env and fill in the values.
# All variables are OPTIONAL — the app runs in demo/mock mode without them.

# ── Database ──
# PostgreSQL connection string (required for persistent data)
# DATABASE_URL=postgresql://user:password@localhost:5432/petsphere

# ── Supabase Auth ──
# Required for real user authentication (sign up / sign in)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key-here

# ── Groq AI ──
# Required for real AI chat responses (without it, mock responses are used)
# GROQ_API_KEY=gsk_your_groq_key_here

# ── Server ──
# PORT=5000
# CORS_ORIGIN=http://localhost:3000
# CORS_ORIGIN=http://localhost:3000,https://your-production-domain.com
# CORS_ORIGIN=*  # allow all origins when needed for demo or preview deployments
# JWT_SECRET=8Tt3q2R9sMz7xJVhL0wFc4YpBu6nG1aD
# JWT_EXPIRES_IN=7d

# ── Email SMTP Configuration ──
# Required to send real emails (without it, emails are logged to the console)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# SMTP_FROM="PetSphere Support <no-reply@petsphere.com>"
