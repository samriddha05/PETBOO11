{
  "name": "petsphere-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "install-all": "npm --prefix frontend install && npm --prefix backend install",
    "postinstall": "npm run install-all",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix backend start",
    "frontend:dev": "npm --prefix frontend run dev",
    "backend:start": "npm --prefix backend start",
    "test:e2e": "mocha tests/e2e/**/*.test.js --timeout 30000",
    "test:performance": "node tests/performance/run-jmeter.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "dotenv": "^17.4.2",
    "mocha": "^11.7.6",
    "prisma": "^7.7.0",
    "selenium-webdriver": "^4.46.0"
  }
}
