{
  "server": {
    "port": 3000,
    "open": true,
    "proxy": {
      "/api": {
        "target": "http://localhost:5000",
        "changeOrigin": true
      },
      "/uploads": {
        "target": "http://localhost:5000",
        "changeOrigin": true
      }
    }
  },
  "build": {
    "outDir": "dist",
    "rollupOptions": {
      "output": {
        "entryFileNames": "assets/[name]-[hash].js",
        "chunkFileNames": "assets/[name]-[hash].js",
        "assetFileNames": "assets/[name]-[hash].[ext]"
      }
    }
  }
}
